{
  "$schema": "node_modules/wrangler/config-schema.json",
  // 프로덕션 Pages 프로젝트는 오직 "mslms" 하나만 사용합니다 (npm run deploy / deploy.sh).
  // 커스텀 도메인: Dashboard → Pages → mslms → Custom domains 에 mindstory.kr · www.mindstory.kr 모두 연결 권장.
  // (www 미연결 시 해당 호스트는 배포에 도달하지 않아 404. Zone Bulk Redirect는 선택.)
  // Git 저장소를 Cloudflare에 연결했다면 CLI 배포와 이중 빌드되지 않도록 Builds 설정을 확인하세요.
  // *.hash.mslms.pages.dev 미리보기가 쌓이면 Dashboard → mslms → Settings → Builds에서 Preview deployments를 제한하세요.
  "name": "mslms",
  "compatibility_date": "2025-12-27",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "mindstory-production",
      "database_id": "99b0d182-a4b0-45d4-81a0-06b50219ac4a"
    }
  ],
  "r2_buckets": [
    {
      "binding": "R2",
      "bucket_name": "mindstory-lms"
    }
  ],
  // Pages/Worker 시크릿 FOREST_GAS_WEBHOOK_URL: GAS 웹앱 /exec 전체 URL (public/forest.html 의 FOREST_SHEETS_WEBHOOK_URL 과 동일·최신 배포 유지, 예: v65).
  "vars": {
    "OPENAI_BASE_URL": "https://api.openai.com/v1",
    "OPENAI_MODEL": "gpt-4o"
  }
}
