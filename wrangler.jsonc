{
  "$schema": "node_modules/wrangler/config-schema.json",
  // 프로덕션 Pages 프로젝트는 오직 "mslms" 하나만 사용합니다 (npm run deploy / deploy.sh).
  // Git 저장소를 Cloudflare에 연결했다면 CLI 배포와 이중 빌드되지 않도록 Builds 설정을 확인하세요.
  // *.hash.mslms.pages.dev 미리보기가 쌓이면 Dashboard → mslms → Settings → Builds에서 Preview deployments를 제한하세요.
  "name": "mslms",
  "compatibility_date": "2025-12-27",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "mindstory-production",
      "database_id": "99b0d182-a4b0-45d4-81a0-06b50219ac4a"
    }
  ],
  "r2_buckets": [
    {
      "binding": "R2",
      "bucket_name": "mindstory-lms"
    }
  ],
  "vars": {
    // R2 퍼블릭 URL (Custom Domain 또는 *.r2.dev) — 비워두면 코드 기본값·R2_PUBLIC_BASE_URL 사용. Pages 대시보드에서도 설정 가능.
    "R2_PUBLIC_URL": "",
    "OPENAI_BASE_URL": "https://api.openai.com/v1",
    "OPENAI_MODEL": "gpt-4o",
    // GAS 웹앱 [새 배포] 시 URL 변경 가능 — forest.html FOREST_SHEETS_WEBHOOK_URL 과 맞출 것
    "FOREST_GAS_WEBHOOK_URL": "https://script.google.com/macros/s/AKfycby8NYv9wk6AcMOc-fIwD354TKRcNEgGOxWqs0chdwj2LUfouue2CyRBfI2f0v0hh6Q/exec"
  }
}
