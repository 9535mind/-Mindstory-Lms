{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mindstory-lms",
  "compatibility_date": "2025-12-27",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "mindstory-production",
      "database_id": "99b0d182-a4b0-45d4-81a0-06b50219ac4a"
    }
  ],
  "r2_buckets": [
    {
      "binding": "R2",
      "bucket_name": "mindstory-lms"
    }
  ],
  "vars": {
    "KAKAO_CLIENT_ID": "your-kakao-client-id",
    "KAKAO_REDIRECT_URI": "https://your-domain.com/api/auth/kakao/callback",
    "GOOGLE_CLIENT_ID": "your-google-client-id",
    "GOOGLE_CLIENT_SECRET": "your-google-client-secret",
    "GOOGLE_REDIRECT_URI": "https://your-domain.com/api/auth/google/callback",
    "OPENAI_BASE_URL": "https://api.openai.com/v1",
    "OPENAI_API_KEY": "your-openai-api-key",
    "APIVIDEO_API_KEY": "your-apivideo-api-key",
    "APIVIDEO_BASE_URL": "https://sandbox.api.video",
    "CLOUDFLARE_ACCOUNT_ID": "your-cloudflare-account-id",
    "STREAM_SIGNING_KEY_ID": "",
    "STREAM_SIGNING_PRIVATE_KEY": "",
    "CLOUDFLARE_API_TOKEN": ""
  }
}
